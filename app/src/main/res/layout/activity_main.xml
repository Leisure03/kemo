<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_color"
    tools:context=".ui.MainActivity">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@android:color/transparent"
        app:elevation="0dp">

        <!-- 横向容器：承载搜索栏与右侧头像，统一设置滚动隐藏行为 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            app:layout_scrollFlags="scroll|enterAlways">

            <!-- 搜索栏 -->

            <!-- 搜索栏外侧右面的用户头像：利用MD3原生圆角样式自动剪裁为圆形 -->

            <com.google.android.material.search.SearchBar
                android:id="@+id/search_bar"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="0dp"
                android:layout_weight="1"
                android:backgroundTint="@color/color_search"
                android:hint="@string/drink_something"
                android:outlineAmbientShadowColor="@color/outlineAmbientShadowColor"
                android:outlineSpotShadowColor="@color/outlineSpotShadowColor"
                app:elevation="14dp"
                app:navigationIcon="@android:drawable/ic_menu_search">
            </com.google.android.material.search.SearchBar>

            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/iv_avatar"
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:layout_marginStart="8dp"
                android:layout_marginEnd="16dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/user_avatar"
                android:scaleType="centerCrop"
                android:src="@mipmap/user_avatar"
                app:shapeAppearanceOverlay="@style/ShapeAppearance.Material3.Corner.Full" />

        </LinearLayout>

    </com.google.android.material.appbar.AppBarLayout>

    <!-- 这里可以放置主界面的正常业务逻辑布局，比如轮播图、饮品列表等 -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">

            <com.youth.banner.Banner
                android:id="@+id/banner_drink"
                android:layout_width="match_parent"
                android:layout_height="200dp"
                app:banner_indicator_normal_color="#D8D8D8"
                app:banner_indicator_selected_color="#F7A37E"
                app:banner_indicator_selected_width="10dp"
                app:banner_indicator_space="10dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <!-- 图标 1 (鲜奶)：链头，设置 chainStyle="spread" 以及统一的 top 约束与间距 -->
            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/img_milk"
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:layout_marginTop="16dp"
                android:background="@mipmap/categories_fresh_milk"
                android:scaleType="centerCrop"
                app:layout_constraintEnd_toStartOf="@+id/img_fruit_tea"
                app:layout_constraintHorizontal_chainStyle="spread"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/banner_drink"
                app:shapeAppearanceOverlay="@style/ShapeAppearance.Material3.Corner.Full" />

            <TextView
                android:id="@+id/tv_milk"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/milk"
                android:textStyle="bold"
                app:layout_constraintEnd_toEndOf="@+id/img_milk"
                app:layout_constraintStart_toStartOf="@+id/img_milk"
                app:layout_constraintTop_toBottomOf="@id/img_milk" />
            <!-- 图标 2 (果茶)：向左连接 img_milk，向右连接 img_milk_tea -->
            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/img_fruit_tea"
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:background="@mipmap/categories_fruit_tea"
                android:scaleType="centerCrop"
                app:layout_constraintEnd_toStartOf="@+id/img_milk_tea"
                app:layout_constraintStart_toEndOf="@+id/img_milk"
                app:layout_constraintTop_toTopOf="@+id/img_milk"
                app:shapeAppearanceOverlay="@style/ShapeAppearance.Material3.Corner.Full" />

            <TextView
                android:id="@+id/tv_fruit_tea"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/fruit_tea"
                android:textStyle="bold"
                app:layout_constraintEnd_toEndOf="@+id/img_fruit_tea"
                app:layout_constraintStart_toStartOf="@+id/img_fruit_tea"
                app:layout_constraintTop_toBottomOf="@+id/img_fruit_tea" />
            <!-- 图标 3 (奶茶)：向左连接 img_fruit_tea，向右连接 img_limited_edition -->
            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/img_milk_tea"
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:background="@mipmap/categories_milk_tea"
                android:scaleType="centerCrop"
                app:layout_constraintEnd_toStartOf="@+id/img_limited_edition"
                app:layout_constraintStart_toEndOf="@+id/img_fruit_tea"
                app:layout_constraintTop_toTopOf="@+id/img_milk"
                app:shapeAppearanceOverlay="@style/ShapeAppearance.Material3.Corner.Full" />

            <TextView
                android:id="@+id/tv_milk_tea"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/milk_tea"
                android:textStyle="bold"
                app:layout_constraintEnd_toEndOf="@+id/img_milk_tea"
                app:layout_constraintStart_toStartOf="@+id/img_milk_tea"
                app:layout_constraintTop_toBottomOf="@+id/img_milk_tea" />

            <!-- 图标 4 (限定)：链尾，向左连接 img_milk_tea，向右连接父容器右边界 -->
            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/img_limited_edition"
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:background="@mipmap/categories_limit_edition"
                android:scaleType="centerCrop"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toEndOf="@+id/img_milk_tea"
                app:layout_constraintTop_toTopOf="@+id/img_milk"
                app:shapeAppearanceOverlay="@style/ShapeAppearance.Material3.Corner.Full"/>

            <TextView
                android:id="@+id/tv_limited_edition"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/limit"
                android:textStyle="bold"
                app:layout_constraintEnd_toEndOf="@+id/img_limited_edition"
                app:layout_constraintStart_toStartOf="@+id/img_limited_edition"
                app:layout_constraintTop_toBottomOf="@+id/img_limited_edition" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_drink_list"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_marginTop="20dp"
                app:layout_constraintEnd_toEndOf="@+id/img_limited_edition"
                app:layout_constraintStart_toStartOf="@+id/img_milk"
                app:layout_constraintTop_toBottomOf="@+id/tv_milk"
                tools:layout_height="300dp"/>
        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- 展开态：全屏沉浸式搜索页面，通过 layout_anchor 锚定 SearchBar -->
    <com.google.android.material.search.SearchView
        android:id="@+id/search_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:backgroundTint="@color/color_search"
        android:hint="@string/try_to_search"
        app:layout_anchor="@id/search_bar"
        tools:visibility="gone">

        <!-- SearchView 展开后，内部承载的建议记录列表 -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_search_results"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager" />

    </com.google.android.material.search.SearchView>
</androidx.coordinatorlayout.widget.CoordinatorLayout>