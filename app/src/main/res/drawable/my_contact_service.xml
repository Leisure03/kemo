<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- 底层：纯色圆形背景 -->
    <item>
        <shape android:shape="oval">
            <solid android:color="#F4C6B6" />
            <size
                android:width="30dp"
                android:height="30dp" />
        </shape>
    </item>

    <!-- 顶层：居中的前景图标 -->
    <item
        android:drawable="@drawable/icon_contact_service"
        android:gravity="center" />
</layer-list>