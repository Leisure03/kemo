<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Theme.Kemo" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/purple_500</item>
        <item name="colorPrimaryVariant">@color/purple_700</item>
        <item name="colorOnPrimary">@color/white</item>
        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/teal_200</item>
        <item name="colorSecondaryVariant">@color/teal_700</item>
        <item name="colorOnSecondary">@color/black</item>
        <!-- Status bar color. -->
        <item name="android:statusBarColor">?attr/colorPrimaryVariant</item>
        <!-- Customize your theme here. -->
    </style>

    <style name="Theme.Kemo.Starting" parent="Theme.SplashScreen">
        <!-- 奶茶奶油底色启动页背景 -->
        <item name="windowSplashScreenBackground">@color/splash_color</item>
        <!-- 奶茶图标 -->
        <item name="windowSplashScreenAnimatedIcon">@drawable/splash_icon</item>
        <!-- 启动动画时长1秒 -->
        <item name="windowSplashScreenAnimationDuration">1000</item>
        <!-- 启动页消失后，自动切换回主主题Theme.Kemo -->
        <item name="postSplashScreenTheme">@style/Theme.Kemo</item>
    </style>
</resources>